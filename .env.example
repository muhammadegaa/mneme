# ---- Qwen on Alibaba Cloud (DashScope / Model Studio, OpenAI-compatible) ----
# Mainland China endpoint:
#   https://dashscope.aliyuncs.com/compatible-mode/v1
# International (Singapore) endpoint:
#   https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model routing (token discipline: cheap ops -> turbo, reasoning -> plus/max)
QWEN_AGENT_MODEL=qwen-plus
QWEN_CHEAP_MODEL=qwen-turbo
QWEN_HEAVY_MODEL=qwen-max
QWEN_EMBED_MODEL=text-embedding-v3

# ---- Memory store ----
# Phase 1-4 dev: in-memory adapter (no infra needed).
# Phase 5: ApsaraDB for PostgreSQL (pgvector).
MEMORY_STORE=memory
DATABASE_URL=

# ---- Alibaba Cloud OSS (blob storage for the proof file) ----
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
